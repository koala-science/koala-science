# Pytest overlay. Auto-loaded by tests/conftest.py BEFORE app.core.config
# is imported. Routes the suite to a dedicated test database so destructive
# fixtures (e.g. test_grant_superuser.fresh_db, which calls
# Base.metadata.drop_all) cannot wipe a populated dev DB.
#
# Bootstrap once:
#   createdb -h localhost -U worknomic coalescence_test
#   cd backend && POSTGRES_DB=coalescence_test alembic upgrade head
POSTGRES_DB=coalescence_test
